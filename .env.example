# ==============================================================================
# MODELO DE VARIÁVEIS DE AMBIENTE — VAULT FINANCE OS
# ==============================================================================
# Este arquivo serve como referência de todas as chaves e segredos necessários 
# para executar a API do Django (Backend) e a aplicação React/Vite (Frontend).
#
# Para usar:
# 1. Copie as variáveis da seção BACKEND para: ./backend/.env
# 2. Copie as variáveis da seção FRONTEND para: ./Ynab/.env
# ==============================================================================

# ------------------------------------------------------------------------------
# 🐳 SEÇÃO 1: BACKEND (Django API / core)
# ------------------------------------------------------------------------------

# Chave secreta de criptografia do Django. Gere uma chave forte para produção!
# Ex: django-insecure-3h#u$v7k%r9w2v8h@q5c...
DJANGO_SECRET_KEY=sua-chave-secreta-do-django-aqui

# Ativa/Desativa o modo de depuração. SEMPRE utilize False em produção!
# Opções: True | False
DEBUG=True

# Lista de hosts permitidos que podem fazer requisições à API (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1,api.vaultfinance.os,*.render.com

# String de conexão com o banco de dados PostgreSQL relacional
# Formato: postgres://<usuario>:<senha>@<host>:<porta>/<nome_do_banco>
DATABASE_URL=postgres://vault_db_user:vault_db_pass@localhost:5432/ynab_prod

# String de conexão com o cache em memória Redis (usado para OTP e throttling)
# Formato: redis://:<senha>@<host>:<porta>/<db_index>
REDIS_URL=redis://localhost:6379/0

# URL de origem permitida do cliente frontend para controle de CORS (sem barra final)
# Ex: https://ynab-five.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://ynab-five.vercel.app

# Nome corporativo que aparecerá no aplicativo Authenticator do usuário ao escanear o QR Code de 2FA
TWO_FACTOR_ISSUER_NAME=Vault Finance OS

# ------------------------------------------------------------------------------
# 💻 SEÇÃO 2: FRONTEND (React / Vite)
# ------------------------------------------------------------------------------

# URL absoluta de conexão do cliente React com a API REST do Django Backend
# Desenvolvimento: http://localhost:8000/api
# Produção: https://ynab-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:8000/api

# ID do cliente Google OAuth2 cadastrado no Google Cloud Console (usado para Google Sign-In)
# Ex: 123456789-abcdef.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=seu-google-client-id-aqui.apps.googleusercontent.com

# Tempo limite máximo (em milissegundos) para as requisições de rede do Axios
VITE_API_TIMEOUT=15000

# Porta de desenvolvimento na qual o servidor do Vite rodará localmente (opcional)
PORT=5173
